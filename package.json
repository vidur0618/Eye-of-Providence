{
  "name": "key-of-providence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "data:refresh:epoch": "node scripts/fetch-epoch.mjs",
    "data:audit:epoch": "node scripts/audit-epoch.mjs",
    "data:derive:epoch": "node scripts/build-epoch-derived.mjs",
    "data:crosswalk:counties": "node --experimental-strip-types scripts/build-county-crosswalk.mjs",
    "data:crosswalk:watersheds": "node --experimental-strip-types scripts/build-watershed-crosswalk.mjs",
    "data:crosswalk:aquifers": "node --experimental-strip-types scripts/build-aquifer-crosswalk.mjs",
    "data:crosswalk:balancing-authorities": "node --experimental-strip-types scripts/build-balancing-authority-crosswalk.mjs",
    "data:crosswalk:utility-territories": "node --experimental-strip-types scripts/build-utility-territory-crosswalk.mjs",
    "data:refresh:state-context": "node scripts/refresh-state-context.mjs",
    "data:build:state-policies": "node scripts/build-state-policies.mjs",
    "data:discover:state-policies": "node scripts/discover-state-policies.mjs",
    "data:discover:policy-index": "node scripts/discover-state-policy-index.mjs",
    "data:audit:live": "node scripts/run-data-audit.mjs",
    "model:calibration-readiness": "node scripts/check-calibration-readiness.mjs",
    "release:audit": "node --experimental-strip-types scripts/audit-release.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "csv-parse": "^7.0.1",
    "d3-geo": "^3.1.1",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
